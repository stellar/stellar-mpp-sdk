# Stellar testnet accounts
STELLAR_RECIPIENT=G...  # Recipient public key (charge demos, e2e)
STELLAR_SECRET=S...     # Payer secret key (charge demos, e2e)

# Funder — used by demo/run-channel-e2e.sh
FUNDER_PUBLIC=G...
FUNDER_SECRET=S...

# Recipient — used by demo/run-channel-e2e.sh
RECIPIENT_PUBLIC=G...
RECIPIENT_SECRET=S...

# Channel demos (demo/run-channel.sh, examples/channel-*.ts)
CHANNEL_CONTRACT=C...       # Deployed one-way-channel contract address
COMMITMENT_PUBKEY=hex...    # ed25519 commitment public key (64 hex chars)
COMMITMENT_SECRET=hex...    # ed25519 commitment secret key (64 hex chars)
# Optional: enables on-chain settlement of MPP close credentials (server broadcasts the close)
CHANNEL_ENVELOPE_SIGNER_SECRET=S... # Sources/signs the on-chain close envelope
CHANNEL_FEE_BUMP_SIGNER_SECRET=S... # Optional: wraps the close in a FeeBumpTransaction

# Server signing — sponsored charge flows 5-6
ENVELOPE_SIGNER_SECRET=S... # Signs the envelope in sponsored mode
FEE_BUMP_SECRET=S...        # Wraps tx in FeeBump (flow 6)

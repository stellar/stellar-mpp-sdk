{
  "compilerOptions": {
    "target": "ES2022",
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./sdk/src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noImplicitReturns": true
  },
  "include": ["sdk/src"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
